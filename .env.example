# Discord設定
DISCORD_TOKEN=your_discord_token_here

# Trello設定
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
TRELLO_BOARD_ID=your_trello_board_id_here
TRELLO_LIST_ID=your_trello_list_id_here

# GitHub設定
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_organization
GITHUB_REPO_PLANNING=your_planning_repo
GITHUB_REPO_DEFAULT=your_default_repo
GITHUB_REPO_FRONT=your_front_repo
GITHUB_REPO_BACK=your_back_repo
GITHUB_REPO_WEB=your_web_repo

# 記事管理機能設定（Claude API）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# データベース設定
# ローカル開発用（PostgreSQL）
# DATABASE_URL=postgresql://user:password@localhost:5432/articles_db

# Render.com本番環境用（自動設定されます）
DATABASE_URL=your_database_url_here

# 環境設定
NODE_ENV=development
